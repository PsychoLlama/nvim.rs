#!/usr/bin/env bash
# Generate a plan using Claude Code, print the plan file path
set -euo pipefail

log() { echo "[plan] $*" >&2; }

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <description>" >&2
  exit 1
fi

description="$1"

log "Running Claude in plan mode..."

# JSON schema to extract the plan file path
schema='{"type":"object","properties":{"plan_path":{"type":"string","description":"Absolute path to the plan file"}},"required":["plan_path"]}'

# Run Claude Code in plan mode with structured output
output=$(claude -p "Let's create a plan. $description

Structure the plan with:
- Overview
- Goals
- Implementation phases (numbered)
- Risks and mitigations
- Success criteria

After writing the plan, respond with the absolute path to the plan file." \
  --permission-mode plan \
  --output-format json \
  --json-schema "$schema")

log "Extracting plan file path..."

# Extract plan file path from structured output
plan_path=$(jq -r '.structured_output.plan_path' <<< "$output")

if [[ -n "$plan_path" && "$plan_path" != "null" && -f "$plan_path" ]]; then
  log "Plan created: $plan_path"
  echo "$plan_path"
else
  log "Error: Could not find plan file path in output"
  jq -r '.result // .error // .' <<< "$output" >&2
  exit 1
fi
