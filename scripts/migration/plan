#!/usr/bin/env bash
# Generate a plan using Claude Code, print the plan file path
set -euo pipefail

log() { echo "[plan] $*" >&2; }

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <description>" >&2
  exit 1
fi

description="$1"

# Check for previous run result
previous_result=""
if [[ -f "ref/run-result" ]]; then
  log "Found previous run result"
  previous_result="

## Previous Work

@ref/run-result contains details from the most recent work."
fi

log "Running Claude in plan mode..."

# Run Claude Code in plan mode with JSON output to capture metadata
output=$(claude -p "Let's create a plan. $description
$previous_result

Structure the plan with:
- Overview
- Goals
- Implementation phases (numbered)
- Risks and mitigations
- Success criteria" \
  --permission-mode plan \
  --output-format json)

log "Extracting plan file path..."

# Extract plan file path from result text
result=$(jq -r '.result' <<< "$output")
plan_path=$(grep -o '/home[^`]*\.md' <<< "$result" | head -1)

if [[ -n "$plan_path" && -f "$plan_path" ]]; then
  log "Plan created: $plan_path"
  echo "$plan_path"
else
  log "Error: Could not find plan file path in output"
  echo "$result" >&2
  exit 1
fi
