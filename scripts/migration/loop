#!/usr/bin/env bash
# Run plan-execute loop until task is complete
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

log() { echo "[loop] $*" >&2; }

max_iterations=10

while [[ $# -gt 0 ]]; do
  case "$1" in
    --max-iterations)
      max_iterations="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 [--max-iterations N] <description>" >&2
  exit 1
fi

description="$1"
iteration=1

if (( max_iterations == 0 )); then
  log "WARNING: Running indefinitely (max_iterations=0)"
fi

log "Starting migration loop for: $description"

while true; do
  log "=== Iteration $iteration ==="

  log "Planning..."
  plan_file=$("$SCRIPT_DIR/plan" "$description")

  log "Executing..."
  "$SCRIPT_DIR/execute" "$plan_file"

  # Safety limit (skip if max_iterations is 0)
  if (( max_iterations > 0 && iteration >= max_iterations )); then
    log "Reached iteration limit ($max_iterations), stopping"
    break
  fi

  ((iteration++))
  log "Continuing to next iteration..."
done

log "Migration loop finished after $iteration iteration(s)"
