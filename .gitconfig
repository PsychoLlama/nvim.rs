# File not recognized by default. Must be linked with git's `include.path`.
# This happens via the flake dev shell.

# Order matters and is the order below: fmt-check rewrites the worktree (treefmt
# always writes; --fail-on-change only adds the exit code), and the ratchet reads
# the ABI ledger. `just refresh` regenerates all of it in that same order.
[hook "fmt-check"]
  event = pre-commit
  command = just fmt-check

[hook "abi-ledger"]
  event = pre-commit
  command = just abi-ledger --check

[hook "ratchet"]
  event = pre-commit
  command = just ratchet --check
